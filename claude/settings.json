{
  "model": "sonnet",
  "permissions": {
    "allow": [
      "Read(~/Developer/**)",
      "Read(~/.claude/**)",
      "Edit(~/Developer/**)",
      "Edit(~/.claude/**)",
      "Write(~/Developer/**)",
      "Write(~/.claude/**)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git stash list*)",
      "Bash(pnpm install*)",
      "Bash(pnpm run*)",
      "Bash(pnpm test*)",
      "Bash(pnpm exec*)",
      "Bash(pnpm lint*)",
      "Bash(pnpm typecheck*)",
      "Bash(pnpm type-check*)",
      "Bash(pnpm format*)",
      "Bash(pnpm prettier*)",
      "Bash(pnpm build*)",
      "Bash(npx tsc*)",
      "Bash(npx prettier*)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(echo *)",
      "Bash(pwd)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh run *)"
    ],
    "deny": [
      "Read(node_modules/**)",
      "Read(.pnpm-store/**)",
      "Read(dist/**)",
      "Read(build/**)",
      "Read(out/**)",
      "Read(.output/**)",
      "Read(.nuxt/**)",
      "Read(.next/**)",
      "Read(.turbo/**)",
      "Read(.vercel/**)",
      "Read(.cache/**)",
      "Read(.parcel-cache/**)",
      "Read(coverage/**)",
      "Read(.nyc_output/**)",
      "Read(**/*.map)",
      "Read(**/*.min.js)",
      "Read(**/*.min.css)",
      "Read(**/*.bundle.js)",
      "Read(**/*.chunk.js)",
      "Read(**/*.lock)",
      "Read(**/*.tsbuildinfo)",
      "Read(**/.DS_Store)",
      "Read(.git/**)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  }
}
